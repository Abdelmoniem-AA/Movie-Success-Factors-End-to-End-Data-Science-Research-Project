    {
      "cell_type": "code",
      "source": [
        "actor_scores = {}\n",
        "\n",
        "for i, row in df.iterrows():\n",
        "    cast = str(row['cast'])\n",
        "    Rating = row['Rating']\n",
        "\n",
        "    actors = [a.strip() for a in cast.split(\",\") if a.strip()]\n",
        "\n",
        "    if len(actors) == 0:\n",
        "        continue\n",
        "\n",
        "    share = Rating / len(actors)\n",
        "\n",
        "    for actor in actors:\n",
        "        if actor in actor_scores:\n",
        "            actor_scores[actor] += share\n",
        "        else:\n",
        "            actor_scores[actor] = share"
      ],
      "metadata": {
        "id": "2p9jP8rfMFLD"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def get_cast_score(cast):\n",
        "  if pd.isna(cast) or str(cast).strip() == \"\":\n",
        "        return None\n",
        "  actors = [a.strip() for a in str(cast).split(\",\") if a.strip()]\n",
        "\n",
        "  scores = [actor_scores.get(actor, 0) for actor in actors]\n",
        "\n",
        "  if len(scores) == 0:\n",
        "      return None\n",
        "\n",
        "  return sum(scores) / len(scores)\n",
        "\n",
        "df[\"cast_popularity\"] = df[\"cast\"].apply(get_cast_score)"
      ],
      "metadata": {
        "id": "QA47Q_nbMPbB"
      },
      "execution_count": null,
      "outputs": []
    },
