    {
      "cell_type": "code",
      "source": [
        "from dash import Dash, html, dcc, Input, Output\n",
        "import plotly.express as px\n",
        "from pyngrok import ngrok\n",
        "\n",
        "public_url = ngrok.connect(8050)\n",
        "print(public_url)\n",
        "\n",
        "app = Dash(__name__)\n",
        "\n",
        "fig = px.histogram(df, x='revenue', nbins=50)\n",
        "\n",
        "app.layout = html.Div([\n",
        "    html.H1(\"Movie Revenue Dashboard\"),\n",
        "\n",
        "    dcc.Graph(id='hist', figure=fig),\n",
        "\n",
        "    html.Label(\"Select Season\"),\n",
        "    dcc.Dropdown(\n",
        "        options=[{'label': s, 'value': s} for s in df['season'].unique()],\n",
        "        value=df['season'].unique()[0],\n",
        "        id='season-dropdown'\n",
        "    ),\n",
        "\n",
        "    dcc.Graph(id='season-plot')\n",
        "])\n",
        "\n",
        "@app.callback(\n",
        "    Output('season-plot', 'figure'),\n",
        "    Input('season-dropdown', 'value')\n",
        ")\n",
        "def update_graph(selected_season):\n",
        "    filtered = df[df['season'] == selected_season]\n",
        "\n",
        "    fig = px.histogram(filtered, x='revenue', nbins=30, title=\"Revenue for \" + selected_season)\n",
        "    return fig\n",
        "\n",
        "if __name__ == '__main__':\n",
        "    app.run(port=8050)"
      ],
      "metadata": {
        "id": "6lOEsYsNNxDv",
        "colab": {
