      "cell_type": "code",
      "source": [
        "def GetSeason2(date):\n",
        "    if pd.isna(date):\n",
        "        return None\n",
        "    month = date.month\n",
        "    if month in [12, 1, 2]:\n",
        "        return \"winter\"\n",
        "    elif month in [3, 4, 5]:\n",
        "        return \"spring\"\n",
        "    elif month in [6, 7, 8]:\n",
        "        return \"summer\"\n",
        "    elif month in [9, 10, 11]:\n",
        "        return \"fall\""
      ],
      "metadata": {
        "id": "byNDlMDI4GiY"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "df['Season'] = df['Season'].fillna(df['release_date'].apply(GetSeason2))"
      ],
      "metadata": {
        "id": "A3HSs89N5xW4"
      },
      "execution_count": null,
      "outputs": []
    },
