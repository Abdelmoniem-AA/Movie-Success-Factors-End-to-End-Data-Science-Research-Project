        "year = int(file_name[:4])\n",
        "\n",
        "with open(file_name, \"r\") as f:\n",
        "    soup = BeautifulSoup(f, \"html.parser\")\n",
        "\n",
        "movies = soup.find_all(\"li\", class_=\"ipc-metadata-list-summary-item\")"
      ],
      "metadata": {
        "id": "ryHYpbnL7UAU"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "for m in movies:\n",
        "    title_tag = m.find(\"h3\")\n",
        "    rating_tag = m.find(\"span\", class_=\"ipc-rating-star--rating\")\n",
        "    meta_tag = m.find(\"span\", class_=\"metacritic-score-box\")\n",
        "\n",
        "    if title_tag:\n",
        "        title_text = title_tag.get_text()\n",
        "        title_clean = re.sub(r\"^\\d+\\.\\s*\", \"\", title_text)\n",
        "\n",
        "        rating = None\n",
        "        if rating_tag:\n",
        "            rating = float(rating_tag.get_text())\n",
        "\n",
        "        metascore = None\n",
        "        if meta_tag:\n",
        "          metascore = int(meta_tag.get_text(strip=True))\n",
        "\n",
        "        Movies_ratings.append([title_clean, year, rating, metascore])"
      ],
      "metadata": {
        "id": "aWXcobP87V2U"
      },
      "execution_count": null,
      "outputs": []
    },
