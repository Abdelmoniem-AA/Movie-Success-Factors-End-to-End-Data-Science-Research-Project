    {
      "cell_type": "markdown",
      "source": [
        "Seasons (Summer, Winter, Fall, and Spring)"
      ],
      "metadata": {
        "id": "im-PQFPwxHji"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import requests\n",
        "\n",
        "url = \"https://www.boxofficemojo.com/season/winter/2026/\"\n",
        "\n",
        "response = requests.get(url)\n",
        "html = response.text\n",
        "\n",
        "parts = url.split(\"/\")\n",
        "Year = int(parts[-2])\n",
        "\n",
        "soup = BeautifulSoup(html, \"html.parser\")\n",
        "\n",
        "len(soup.find_all(\"tr\"))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "_MTzDS4NxPFG",
        "outputId": "9ef981a4-f587-4206-ec1a-11078ea43bb8"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": [
              "166"
            ]
          },
          "metadata": {},
          "execution_count": 138
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "def get_season(release_date):\n",
        "  if release_date.startswith(\"Dec\") or release_date.startswith(\"Jan\") or release_date.startswith(\"Feb\"):\n",
        "    return \"winter\"\n",
        "  elif release_date.startswith(\"Mar\") or release_date.startswith(\"Apr\") or release_date.startswith(\"May\"):\n",
        "    return \"spring\"\n",
        "  elif release_date.startswith(\"Jun\") or release_date.startswith(\"Jul\") or release_date.startswith(\"Aug\"):\n",
        "    return \"summer\"\n",
        "  elif release_date.startswith(\"Sep\") or release_date.startswith(\"Oct\") or release_date.startswith(\"Nov\"):\n",
        "    return \"fall\""
      ],
      "metadata": {
        "id": "vs7m19aWuXM3"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "rows = soup.find_all(\"tr\")\n",
        "\n",
        "data = []\n",
        "\n",
        "for row in rows:\n",
        "    cols = row.find_all(\"td\")\n",
        "\n",
        "    if len(cols) >= 3:\n",
        "        title = cols[1].text.strip()\n",
        "        release_date = cols[8].text.strip()\n",
        "        season = get_season(release_date)\n",
        "        data.append([title, season, Year])\n",
        "\n",
        "data[:5]"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "v1qyzEaq4zFu",
