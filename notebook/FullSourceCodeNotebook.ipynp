    {
      "cell_type": "code",
      "source": [
        "RandomForest_y_pred = RandomForestModel.predict(x_test)"
      ],
      "metadata": {
        "id": "8u3Ep3duQ20F"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"R2 score:\", r2_score(y_test, RandomForest_y_pred))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "BHya8Oq1Q7zo",
