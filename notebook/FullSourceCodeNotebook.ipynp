    {
      "cell_type": "markdown",
      "source": [
        "IMDB Ratings"
      ],
      "metadata": {
        "id": "q-kXQEgCHVaV"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "file_name = \"2026IMDbR.html\"\n",
        "year = 2025\n",
        "\n",
        "with open(file_name, \"r\") as f:\n",
        "    soup = BeautifulSoup(f, \"html.parser\")\n",
        "\n",
        "movies = soup.find_all(\"li\", class_=\"ipc-metadata-list-summary-item\")"
      ],
      "metadata": {
        "id": "elww-kMjHU1F"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import re\n",
        "\n",
        "Movies_ratings = []\n",
        "\n",
        "for m in movies:\n",
        "    title_tag = m.find(\"h3\")\n",
        "    rating_tag = m.find(\"span\", class_=\"ipc-rating-star--rating\")\n",
        "\n",
        "    if title_tag:\n",
        "        title_text = title_tag.get_text()\n",
        "        title_clean = re.sub(r\"^\\d+\\.\\s*\", \"\", title_text)\n",
        "\n",
        "        rating = None\n",
        "        if rating_tag:\n",
        "            rating = float(rating_tag.get_text())\n",
        "\n",
        "        Movies_ratings.append([title_clean, year, rating])\n",
        "\n",
        "Movies_ratings[:5]"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "DLxJIVUrJJsI",
        "outputId": "17c4f914-11cc-4ba0-ad56-b51502c11c3d"
      },
      "execution_count": null,
