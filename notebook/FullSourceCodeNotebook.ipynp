    {
      "cell_type": "code",
      "source": [
        "Q1Revenue = df['Revenue'].quantile(0.25)\n",
        "Q3Revenue = df['Revenue'].quantile(0.75)\n",
        "IQR_revenue = Q3Revenue - Q1Revenue\n",
        "lower_revenue = Q1Revenue - 1.5 * IQR_revenue\n",
        "upper_revenue = Q3Revenue + 1.5 * IQR_revenue\n",
        "outliers_revenue = df[(df['Revenue'] < lower_revenue) | (df['Revenue'] > upper_revenue)]\n",
        "outliers_revenue.shape"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "FVfgDeapYSHZ",
        "outputId": "4fa89731-5fab-479b-de34-f3f41f59e5c9"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": [
              "(590, 10)"
            ]
          },
          "metadata": {},
          "execution_count": 322
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "Q1Budget = df['budget'].quantile(0.25)\n",
        "Q3Budget = df['budget'].quantile(0.75)\n",
        "IQR_Budget = Q3Budget - Q1Budget\n",
        "lower_Budget = Q1Budget - 1.5 * IQR_Budget\n",
        "upper_Budget = Q3Budget + 1.5 * IQR_Budget\n",
        "outliers_Budget = df[(df['budget'] < lower_Budget) | (df['budget'] > upper_Budget)]\n",
        "outliers_Budget.shape"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "aLzgXige6Ath",
        "outputId": "fa4f3ee9-724e-46ea-e620-a25ccc893381"
