    {
      "cell_type": "code",
      "source": [
        "df[\"Revenue_bin\"] = pd.qcut(df[\"Revenue\"], q=5)\n",
        "\n",
        "df[\"Rating\"] = df[\"Rating\"].fillna(\n",
        "    df.groupby(\"Revenue_bin\")[\"Rating\"].transform(\"median\")\n",
        ")\n",
        "\n",
        "df.drop(columns=[\"Revenue_bin\"], inplace=True)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
