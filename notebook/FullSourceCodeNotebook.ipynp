          },
          "metadata": {},
          "execution_count": 1
        }
      ],
      "source": [
        "from bs4 import BeautifulSoup\n",
        "import csv\n",
        "\n",
        "file_name = \"BoxOfficeMojo2026.html\"\n",
        "\n",
        "year = int(file_name[-9:-5])\n",
        "\n",
        "with open(file_name, \"r\") as f:\n",
        "    html = f.read()\n",
        "\n",
        "soup = BeautifulSoup(html, \"html.parser\")\n",
        "\n",
        "len(soup.find_all(\"tr\"))"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "rows = soup.find_all(\"tr\")\n",
        "\n",
        "data = []\n",
        "\n",
        "for row in rows:\n",
        "    cols = row.find_all(\"td\")\n",
        "\n",
        "    if len(cols) >= 3:\n",
        "        title = cols[1].text.strip()\n",
        "        revenue = int(cols[2].text.strip().replace(\"$\", \"\").replace(\",\", \"\"))\n",
        "\n",
        "\n",
        "        data.append([title, year, revenue])\n",
        "\n",
        "data[:5]"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "zeDITK9bwfKW",
        "outputId": "c4e08893-f570-4477-e010-9f2e183d8bac"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": [
              "[['The Super Mario Galaxy Movie', 2026, 755815355],\n",
              " ['Pegasus 3', 2026, 641059523],\n",
              " ['Project Hail Mary', 2026, 577222148],\n",
              " ['Hoppers', 2026, 367857474],\n",
              " ['Wuthering Heights', 2026, 241301072]]"
            ]
          },
          "metadata": {},
          "execution_count": 2
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "with open(\"Movies.csv\", \"w\", newline=\"\") as f:\n",
        "    writer = csv.writer(f)\n",
        "    writer.writerow([\"Title\", \"Year\", \"Revenue\"])\n",
        "    writer.writerows(data)"
      ],
      "metadata": {
        "id": "TOP2TpzGwumS"
      },
      "execution_count": null,
      "outputs": []
    },
