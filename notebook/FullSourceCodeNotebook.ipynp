      ]
    },
    {
      "cell_type": "code",
      "source": [
        "importances = RandomForestModel.feature_importances_\n",
        "\n",
        "feature_names = X.columns\n",
        "for i, j in zip(feature_names, importances):\n",
        "    print(f\"{i}: {j}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "pNfMOaUuRmEN",
        "outputId": "27a146ca-3bbb-42cd-9569-650fe3b8bab9"
