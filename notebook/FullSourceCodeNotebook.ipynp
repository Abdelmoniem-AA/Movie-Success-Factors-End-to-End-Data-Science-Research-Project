    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "\n",
        "df = pd.read_csv(\"Movies.csv\")\n",
        "imdb = pd.DataFrame(Movies_ratings, columns=[\"Title\", \"Year\", \"Rating\", \"Critics ratings\"])\n",
        "df[\"Year\"] = df[\"Year\"].astype(int)\n",
        "imdb[\"Year\"] = imdb[\"Year\"].astype(int)\n",
        "\n",
        "df['original_order'] = range(len(df))\n",
        "df = df.sort_values(\"Year\")\n",
        "imdb = imdb.sort_values(\"Year\")\n",
        "\n",
        "df = pd.merge_asof(df, imdb, on=\"Year\", by=\"Title\", tolerance=1, direction=\"nearest\")\n",
        "\n",
        "df = df.sort_values(\"original_order\")\n",
        "\n",
        "df = df.drop(columns=['original_order']).reset_index(drop=True)\n",
        "\n",
        "df.to_csv(\"Movies_with_ratings.csv\", index=False)\n",
        "\n",
        "df.head()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
