    {
      "cell_type": "code",
      "source": [
        "df['original_order'] = range(len(df))\n",
        "df = df.sort_values(\"Year\")\n",
        "MoreDetails = MoreDetails.sort_values(\"Year\")\n",
        "\n",
        "df = pd.merge_asof(df, MoreDetails, on=\"Year\", by=\"Title\", tolerance=1, direction=\"nearest\")\n",
        "\n",
        "df = df.sort_values(\"original_order\")\n",
        "\n",
        "df = df.drop(columns=['original_order']).reset_index(drop=True)\n",
        "\n",
        "df.head()"
      ],
